&#125;
.button &#123;
    transition: all 0.3s ease;
&#125;

.button:hover &#123;
    transform: rotate(360deg);
&#125;
.button:hover:after &#123;
    text-align: center;
    content: &quot;间歇性发疯！&quot;;
    position: absolute;
